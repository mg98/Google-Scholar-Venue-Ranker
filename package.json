{
  "name": "gsvr",
  "version": "2.2.0",
  "private": true,
  "type": "commonjs",
  "description": "Build tooling for the Google Scholar Venue Ranker Chrome extension.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate:rankings-index": "node scripts/generate_rankings_index.mjs",
    "clean": "node scripts/clean.mjs",
    "build": "node scripts/build.mjs",
    "test": "node GSVR/tests/run_tests.js",
    "test:unit": "node GSVR/tests/run_tests.js",
    "test:venue-accuracy": "node GSVR/venue_accuracy_csv.js",
    "test:score": "node GSVR/tests/run_score_tests.js",
    "test:dblp": "node GSVR/tests/run_dblp_venue_catalog_tests.js",
    "test:dblp-venues": "node GSVR/tests/run_dblp_venue_catalog_tests.js",
    "benchmark:accuracy:fixtures": "node GSVR/tests/generate_accuracy_fixtures.js",
    "benchmark:accuracy:real-fixtures": "node GSVR/tests/generate_real_fixtures.js",
    "tune:thresholds": "node scripts/tune_thresholds.mjs",
    "benchmark:accuracy": "node GSVR/tests/benchmark_accuracy.js",
    "benchmark:matching": "node GSVR/tests/benchmark_accuracy.js",
    "benchmark:scoring": "node GSVR/tests/run_score_tests.js",
    "benchmark:calibration": "node GSVR/tests/run_score_tests.js",
    "benchmark:all": "npm run benchmark:matching && npm run benchmark:scoring && npm run benchmark:calibration",
    "venue:accuracy": "npm run test:venue-accuracy",
	"zip": "npm run build && node scripts/zip.mjs"
  }
}
